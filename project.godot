; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via script.

[application]

config/name="BOOKWAR"
config/description="RPG with card battles based on the Russian alphabet"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://icon.png"

[autoload]

BookwarConst="*res://scripts/core/constants.gd"
I18n="*res://scripts/core/i18n.gd"
GameState="*res://scripts/core/game_state.gd"
InventoryManager="*res://scripts/core/inventory.gd"
AlphabetData="*res://scripts/core/alphabet_data.gd"
PunctuationData="*res://scripts/core/punctuation_data.gd"
SpellData="*res://scripts/core/spell_data.gd"
QuestData="*res://scripts/core/quest_data.gd"
Music="*res://scripts/core/music.gd"
NetworkManager="*res://scripts/multiplayer/network_manager.gd"
SaveManager="*res://scripts/core/save_manager.gd"
TacticalCombat="*res://scripts/core/tactical_combat.gd"
VoiceChat="*res://scripts/multiplayer/voice_chat.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=2
window/handheld/orientation=0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

