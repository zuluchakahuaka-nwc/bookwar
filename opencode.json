{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "zai-mcp-server": {
      "type": "local",
      "command": ["npx", "-y", "@z_ai/mcp-server"],
      "enabled": true,
      "environment": {
        "Z_AI_API_KEY": "***REMOVED:Z_AI_API_KEY***",
        "Z_AI_MODE": "ZAI"
      }
    }
  },
  "permission": {
    "bash": { "npm *": "allow", "npx *": "allow", "node *": "allow", "*": "ask" },
    "edit": "allow",
    "read": "allow"
  }
}
