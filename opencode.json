{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "zai-mcp-server": {
      "type": "local",
      "command": ["npx", "-y", "@z_ai/mcp-server"],
      "enabled": true,
      "environment": {
        "Z_AI_API_KEY": "***REMOVED:Z_AI_API_KEY***",
        "Z_AI_MODE": "ZAI"
      }
    }
  },
  "permission": {
    "bash": { "*": "allow" },
    "edit": "allow",
    "read": "allow",
    "task": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todowrite": "allow",
    "webfetch": "allow"
  }
}
