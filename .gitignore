# Android — Godot export template (regenerated by "Install Android Build Template")
# Contains a ~200MB godot-lib.aar + local gradle caches. Keep only the source
# side of the Android subproject (scripts/docs/server under ANDROID_VERSION/).
android/

# Android subproject — only track source/scripts/docs, ignore build artifacts.
# See AGENTS.md §0.12 (cleanup rule) and §21 for what stays vs what goes.
ANDROID_VERSION/test_project/
ANDROID_VERSION/tests/
ANDROID_VERSION/testandroid_*.zip
ANDROID_VERSION/builds/*.apk
ANDROID_VERSION/builds/*.aab
